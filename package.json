{
  "name": "multiplayer-chess-online",
  "version": "1.0.0",
  "description": "Real-time multiplayer chess with rooms, clocks, chat, accounts and leaderboard.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "npm run lint && npm run typecheck",
    "dev": "cross-env NODE_ENV=development tsx watch --ignore \"**/*.timestamp-*.mjs\" --ignore \"**/dist/**\" --ignore \"**/node_modules/**\" src/server/index.ts",
    "build": "npm run build:client && npm run build:ssr && npm run build:server",
    "build:client": "vite build --outDir dist/client --ssrManifest",
    "build:ssr": "vite build --ssr src/client/entry-server.tsx --outDir dist/server-entry",
    "build:server": "vite build --ssr src/server/index.ts --outDir dist/server",
    "start": "node dist/server/index.mjs",
    "lint-fix": "eslint . --ext .js,.jsx,.mjs,.ts,.tsx --fix",
    "lint": "eslint . --ext .js,.jsx,.mjs,.ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "bcryptjs": "^3.0.3",
    "chess.js": "^1.4.0",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cross-env": "^10.1.0",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.5",
    "nanoid": "^5.1.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie": "^1.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/types": "^8.61.1",
    "@typescript-eslint/typescript-estree": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^9.39.4",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "@eslint/js": "^10.0.1",
    "@eslint/eslintrc": "^3.3.5"
  }
}
